# aicommits profile — copy to ~/.config/aicommits/default.env and fill in.
# Each key maps to an `aicommits config set` setting inside the container.
# Do NOT commit real keys: files matching *.env are gitignored.

OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
type=conventional
locale=en
timeout=20000
